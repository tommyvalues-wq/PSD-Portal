<%- include('layout-top') %>
<section class="panel">
  <h1>Dashboard</h1>
  <div class="stat-grid">
    <div class="stat"><strong><%= stats.firefighters %></strong><span>Firefighters</span></div>
    <div class="stat"><strong><%= stats.cases %></strong><span>Disciplinary Cases</span></div>
    <div class="stat"><strong><%= stats.pst %></strong><span>PST Members</span></div>
    <div class="stat"><strong><%= stats.gold %></strong><span>Gold Command</span></div>
    <div class="stat"><strong><%= stats.silver %></strong><span>Silver Command</span></div>
    <div class="stat"><strong><%= stats.bronze %></strong><span>Bronze Command</span></div>
  </div>
  <h2>Recent Audit Activity</h2>
  <table><thead><tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th><th>Details</th></tr></thead><tbody>
  <% recent.forEach(r => { %><tr><td><%= r.created_at %></td><td><%= r.username || 'System' %></td><td><%= r.action %></td><td><%= r.entity %> #<%= r.entity_id %></td><td><%= r.details %></td></tr><% }) %>
  </tbody></table>
</section>
<%- include('layout-bottom') %>
