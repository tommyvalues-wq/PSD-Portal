*{box-sizing:border-box} body{margin:0;font-family:Inter,Arial,Helvetica,sans-serif;background:#111;color:white}.topbar{background:#0d0d0d;border-top:5px solid #b40000;border-bottom:1px solid #7d1118;display:flex;align-items:center;justify-content:space-between;padding:18px 38px;gap:20px}.brand{display:flex;align-items:center;gap:18px;color:white;text-decoration:none}.crest{width:66px;height:66px;border-radius:50%;background:#b40000;display:flex;align-items:center;justify-content:center;font-weight:900}.brand h1{margin:0;font-size:25px}.brand h1 span,footer span{color:#e21b23}.brand p{margin:6px 0 0;color:#bbb;font-size:13px;letter-spacing:2px}nav{display:flex;align-items:center;gap:22px;flex-wrap:wrap}nav a{color:white;text-decoration:none;font-weight:900;text-transform:uppercase}.nav-btn,.primary-btn{background:#c1121f;color:white;border:0;border-radius:6px;padding:13px 18px;font-weight:900;text-decoration:none;display:inline-block}.secondary-btn{background:#272727;color:white;border:1px solid #444;border-radius:6px;padding:13px 18px;font-weight:900;text-decoration:none;display:inline-block}button{cursor:pointer}main{min-height:calc(100vh - 140px)}.hero{min-height:590px;background:linear-gradient(90deg,#050505 0%,#090909 48%,rgba(0,0,0,.55)),url('https://images.unsplash.com/photo-1597424216809-3ba9864aaf32?auto=format&fit=crop&w=1800&q=80');background-size:cover;background-position:center;display:flex;align-items:center;padding:80px 95px;border-bottom:1px solid #333}.hero-content{max-width:760px}.eyebrow{color:#e21b23;font-weight:900;letter-spacing:2.5px}.center{text-align:center}.hero h2{font-size:58px;line-height:1.05;margin:14px 0;text-transform:uppercase}.hero h3{font-size:25px;margin:0 0 30px}.hero-main{font-size:22px}.hero-muted{font-size:19px;color:#cfcfcf;line-height:1.5}.modules{background:#151515;padding:36px 65px 55px;text-align:center}.modules h2{font-size:32px;margin-top:0}.module-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;text-align:left}.module-card{border:1px solid #333;background:#1b1b1b;padding:24px;border-radius:8px;min-height:175px}.icon{font-size:38px}.module-card p,.notice{color:#cfcfcf;line-height:1.45}.notice{margin-top:24px;border:1px solid #333;border-radius:8px;padding:20px;text-align:left}.panel{margin:36px auto;max-width:1250px;background:#171717;border:1px solid #303030;border-radius:14px;padding:28px;box-shadow:0 20px 50px rgba(0,0,0,.25)}.narrow{max-width:620px}.page-head{display:flex;justify-content:space-between;align-items:center;gap:18px;flex-wrap:wrap}.form{display:grid;gap:12px}.form input,.form textarea,.form select,.search-bar input,.search-bar select{width:100%;background:#0d0d0d;color:white;border:1px solid #393939;border-radius:8px;padding:13px}.form textarea{min-height:110px}.search-bar{display:grid;grid-template-columns:1fr 220px auto auto;gap:10px;margin:20px 0}table{width:100%;border-collapse:collapse;margin-top:20px;background:#111;border-radius:10px;overflow:hidden}th,td{padding:14px;border-bottom:1px solid #2d2d2d;text-align:left}th{background:#202020;color:#ddd}td a{color:#ff4d57;font-weight:700}.inline-form{display:inline}.inline-form button,td button{background:#2a2a2a;color:#fff;border:1px solid #555;border-radius:5px;padding:7px 10px}.badge{display:inline-block;padding:6px 10px;border-radius:999px;background:#333;border:1px solid #555;font-weight:800}.command-bronze{background:#5b3417;border-color:#b87333}.command-silver{background:#444;border-color:#c0c0c0}.command-gold{background:#5a4800;border-color:#d4af37}.command-no{background:#242424}.stat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin:24px 0}.stat{background:#101010;border:1px solid #333;border-radius:12px;padding:22px}.stat strong{display:block;font-size:34px;color:#ff3b45}.stat span{color:#ccc}footer{text-align:center;color:#999;padding:22px;border-top:1px solid #222;background:#0d0d0d}.checkbox{display:inline-flex;align-items:center;gap:6px;margin:0 8px}@media(max-width:1000px){.topbar{align-items:flex-start;flex-direction:column}.hero{padding:50px 25px}.hero h2{font-size:38px}.module-grid,.stat-grid{grid-template-columns:1fr}.search-bar{grid-template-columns:1fr}}
