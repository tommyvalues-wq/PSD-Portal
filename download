<%- include('layout-top') %>
<section class="panel"><div class="page-head"><h1>Disciplinary Actions</h1><a class="primary-btn" href="/discipline/new">Add Action</a></div><table><thead><tr><th>Date</th><th>Firefighter</th><th>Type</th><th>Severity</th><th>Summary</th><th>Outcome</th><th>Issued By</th><th>Actions</th></tr></thead><tbody><% cases.forEach(c=>{ %><tr><td><%= c.action_date %></td><td><%= c.firefighter %></td><td><%= c.type %></td><td><%= c.severity %></td><td><%= c.summary %></td><td><%= c.outcome || '-' %></td><td><%= c.issuer %></td><td><a href="/discipline/<%= c.id %>/edit">Edit</a><form method="post" action="/discipline/<%= c.id %>/delete" class="inline-form"><button>Delete</button></form></td></tr><% }) %></tbody></table></section>
<%- include('layout-bottom') %>
