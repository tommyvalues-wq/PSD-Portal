<%- include('layout-top') %>
<section class="panel"><h1>User Management</h1><form method="post" action="/admin/users/add" class="search-bar"><input name="roblox_id" required placeholder="Roblox User ID"><input name="username" placeholder="Username"><select name="role"><option value="member">Member</option><option value="pst">Professional Standards</option><option value="owner">Owner</option></select><button class="primary-btn">Add / Update User</button></form><table><thead><tr><th>Roblox ID</th><th>Username</th><th>Role</th><th>Allowed</th><th>Actions</th></tr></thead><tbody><% users.forEach(u=>{ %><tr><td><%= u.roblox_id %></td><td><%= u.username %></td><td><%= roles[u.role] || u.role %></td><td><%= u.is_allowed ? 'Yes' : 'No' %></td><td><form method="post" action="/admin/users/<%= u.id %>/role" class="inline-form"><select name="role"><option value="member" <%= u.role==='member'?'selected':'' %>>Member</option><option value="pst" <%= u.role==='pst'?'selected':'' %>>PST</option><option value="owner" <%= u.role==='owner'?'selected':'' %>>Owner</option></select><label class="checkbox"><input type="checkbox" name="is_allowed" <%= u.is_allowed?'checked':'' %>> Allowed</label><button>Save</button></form></td></tr><% }) %></tbody></table></section>
<%- include('layout-bottom') %>
